# =============================================================================
# NoirKart Environment Configuration
# =============================================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real credentials below
#   3. NEVER commit your .env file — it's already in .gitignore
#
# SECURITY NOTES:
#   - Variables prefixed with VITE_ are bundled into the CLIENT-SIDE build.
#     This means they are visible to anyone who inspects your site's JS bundle.
#   - VITE_FIREBASE_* keys are designed to be public. Protect them with
#     Firebase Security Rules + authorized domains in the Firebase Console.
#   - VITE_GEMINI_API_KEY should be restricted in Google Cloud Console:
#     APIs & Services → Credentials → API Key → Application Restrictions →
#     HTTP referrers → Add your domain (e.g., noirkart.com/*)
#   - RESEND_API_KEY is server-side only (no VITE_ prefix) — keep it secret.
# =============================================================================

# --- Firebase (Cloud Database & Auth) ----------------------------------------
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id-here
VITE_FIREBASE_APP_ID=your-firebase-app-id-here

# --- Google Gemini AI ---------------------------------------------------------
# Enables AI product generation in the Admin Panel.
# Get your free API key at: https://aistudio.google.com/apikey
# ⚠️  SECURITY: Restrict this key to your domain in Google Cloud Console.
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# --- Pinterest Integrations (Optional) ----------------------------------------
VITE_PINTEREST_VERIFICATION_CODE=your-pinterest-domain-verify-meta-code-here
VITE_PINTEREST_TAG_ID=your-pinterest-pixel-tag-id-here

# --- Google Analytics (Optional) ----------------------------------------------
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here

# --- Google Search Console (Optional) ----------------------------------------
VITE_GOOGLE_SITE_VERIFICATION=your-google-search-console-verification-code-here

# --- Site URL (for sitemap & SEO) --------------------------------------------
VITE_SITE_URL=https://noirkart.com

# --- Resend (Contact Form Email) ---------------------------------------------
# ⚠️  SERVER-SIDE ONLY — this key is never sent to the browser.
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here

# =============================================================================
# ADMIN SETUP (after removing hardcoded backdoor)
# =============================================================================
# To set up admin access:
#   1. Create a user in Firebase Auth Console with a STRONG password
#   2. In Firestore, create a document: admins/{your-admin-email}
#      with field: role = "admin"
#   3. Sign in with that account — admin panel will unlock automatically
# =============================================================================
