# noirkart Cloud Firebase Database Configurations
# Copy this file to .env and fill in your Firebase Web App credentials to connect a real persistent Firestore database!

VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id-here
VITE_FIREBASE_APP_ID=your-firebase-app-id-here

# Google Gemini AI — Enables AI product generation in the Admin Panel
# Get your free API key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Pinterest Integrations (Optional)
VITE_PINTEREST_VERIFICATION_CODE=your-pinterest-domain-verify-meta-code-here
VITE_PINTEREST_TAG_ID=your-pinterest-pixel-tag-id-here

# Google Analytics Integration (Optional)
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here

# Google Search Console Verification (Optional)
VITE_GOOGLE_SITE_VERIFICATION=your-google-search-console-verification-code-here
